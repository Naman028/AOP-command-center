{
  "name": "aop-command-center",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Secure AOP Command Center MERN monolith.",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "predev": "npm run dev:stop",
    "dev": "concurrently -k -n API,WEB -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "dev:stop": "node scripts/stop-dev-ports.js",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "security:check": "npm audit --workspaces --audit-level=high"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
